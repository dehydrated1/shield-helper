{
  "schemaVersion": 1,
  "id": "shield-helper",
  "version": "${version}",
  "name": "Shield Helper",
  "description": "Client-side shield interaction helper with configurable safety controls.",
  "authors": ["Shield Helper Contributors"],
  "contact": {},
  "license": "MIT",
  "environment": "client",
  "entrypoints": {
    "main": [
      "com.example.shieldhelper.ShieldHelperMod"
    ],
    "client": [
      "com.example.shieldhelper.client.ShieldHelperClient"
    ],
    "modmenu": [
      "com.example.shieldhelper.client.ShieldHelperModMenu"
    ]
  },
  "mixins": [
    "shield-helper.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.18.1",
    "fabric-api": "*",
    "minecraft": "~1.21.11",
    "java": ">=21"
  },
  "suggests": {
    "modmenu": ">=17.0.0"
  }
}
